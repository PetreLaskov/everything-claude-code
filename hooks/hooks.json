{
  "$schema": "https://raw.githubusercontent.com/anthropics/claude-code/main/settings-schema.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "description": "Load learner profile and inject session context at startup",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start-loader.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "description": "Warn-only guardrail advice before file writes",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/guardrail-advisor.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "description": "Capture behavioral signals from tool usage for level calibration",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/level-signal-capture.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "description": "Inject teaching annotation guidance based on learner level",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/teaching-annotation.js",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "description": "Persist learner profile and session history on session end",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/hooks/learner-state-persist.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
